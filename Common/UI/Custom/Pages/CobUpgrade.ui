$C = "../Common.ui";
$Sounds = "../Sounds.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@Container {
    Anchor: (Width: 1210, Height: 700);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (...$C.@DefaultLabelStyle, FontSize: 22, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 34);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

      Label #TierLabel {
        Style: (...$C.@DefaultLabelStyle, FontSize: 17, TextColor: #9ed9ff, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 28, Bottom: 4);
      }

      Label #TierCompare {
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #c7d7e7, HorizontalAlignment: Center);
        Anchor: (Height: 22, Bottom: 8);
      }

      Label #RowsHeader {
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #a9dcff, RenderBold: true);
        Anchor: (Height: 20, Bottom: 4);
      }

      Group #TableHeader {
        LayoutMode: Left;
        Anchor: (Height: 30, Bottom: 4);
        Background: (Color: #263546(0.95));
        Padding: (Left: 8, Right: 8);

        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true); Text: "Resource"; Anchor: (Width: 210); }
        Label #ColChance { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center); Anchor: (Width: 150); }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
        Label #ColNext { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center); Anchor: (Width: 180); }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
        Label #ColMin { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center); Anchor: (Width: 170); }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
        Label #ColHour { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center); Anchor: (Width: 170); }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
        Label #ColDay { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center); Anchor: (Width: 170); }
      }

      Group #Rows {
        LayoutMode: TopScrolling;
        Anchor: (Height: 330, Bottom: 8);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 4);
        Group #Row0 {
          LayoutMode: Left;
          Anchor: (Height: 32, Bottom: 3);
          Padding: (Left: 8, Right: 8);
          Background: (Color: #131d28(0.86));

          ItemIcon #Row0Icon { Anchor: (Width: 22, Height: 22, Right: 8); }
          Label #Row0Name { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff); Anchor: (Width: 180); }
          Label #Row0Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6e6ff, HorizontalAlignment: Center); Anchor: (Width: 150); }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 180);
            Label #Row0NextBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6e6ff); Anchor: (Width: 84); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row0NextPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 74); }
            Label #Row0NextNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 74); }
            Label #Row0NextZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 74); }
          }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 170);
            Label #Row0MinBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cfd9e6); Anchor: (Width: 96); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row0MinPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row0MinNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row0MinZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
