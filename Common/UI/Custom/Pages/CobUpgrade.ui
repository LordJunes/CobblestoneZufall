            Label #Row10HourPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row10HourNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row10HourZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
          }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 170);
            Label #Row10DayBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cfd9e6); Anchor: (Width: 96); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row10DayPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row10DayNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row10DayZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
          }
        }
        Group #Row11 {
          LayoutMode: Left;
          Anchor: (Height: 32, Bottom: 3);
          Padding: (Left: 8, Right: 8);
          Background: (Color: #131d28(0.86));

          ItemIcon #Row11Icon { Anchor: (Width: 22, Height: 22, Right: 8); }
          Label #Row11Name { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff); Anchor: (Width: 180); }
          Label #Row11Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6e6ff, HorizontalAlignment: Center); Anchor: (Width: 150); }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 180);
            Label #Row11NextBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6e6ff); Anchor: (Width: 84); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row11NextPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 74); }
            Label #Row11NextNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 74); }
            Label #Row11NextZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 74); }
          }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 170);
            Label #Row11MinBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cfd9e6); Anchor: (Width: 96); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row11MinPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11MinNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11MinZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
          }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 170);
            Label #Row11HourBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cfd9e6); Anchor: (Width: 96); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row11HourPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11HourNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11HourZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
          }
          Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #4f6077, HorizontalAlignment: Center); Text: "|"; Anchor: (Width: 8); }
          Group { LayoutMode: Left; Anchor: (Width: 170);
            Label #Row11DayBase { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cfd9e6); Anchor: (Width: 96); }
            Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Text: "   "; Anchor: (Width: 16); }
            Label #Row11DayPos { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #70ff70, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11DayNeg { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7070, RenderBold: true); Anchor: (Width: 58); }
            Label #Row11DayZero { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9eb1c9); Anchor: (Width: 58); }
          }
        }
      }

      Group #ActionSlot {
        Anchor: (Height: 92, Bottom: 8);
        Background: (Color: #1a2432(0.75));
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #UpgradePrompt {
          Anchor: (Full: 0);
          LayoutMode: Top;
          Visible: false;
          Label #PromptText { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d6e6ff, HorizontalAlignment: Center, Wrap: true); Anchor: (Height: 28, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Height: 32);
            TextButton #PromptBuyButton { Anchor: (Width: 180, Height: 30, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
            TextButton #PromptCancelButton { Anchor: (Width: 140, Height: 30); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
          }
        }

        Group #UpgradeConfirm {
          Anchor: (Full: 0);
          LayoutMode: Top;
          Visible: false;
          Label #ConfirmText { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d6e6ff, HorizontalAlignment: Center, Wrap: true); Anchor: (Height: 44, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Height: 32);
            TextButton #ConfirmBuyButton { Anchor: (Width: 180, Height: 30, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
            TextButton #ConfirmCancelButton { Anchor: (Width: 140, Height: 30); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
          }
        }
      }

      Label #YieldInfo {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, TextColor: #7dd8ff, HorizontalAlignment: Center, Wrap: true);
        Anchor: (Height: 30, Bottom: 8);
      }

      Group {
        LayoutMode: Center;
        Anchor: (Height: 42, Bottom: 6);

        TextButton #UpgradeButtonEnabled {
          Anchor: (Width: 250, Height: 36, Right: 8);
          Background: (Color: #285f34);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                TextColor: #c7ffd1,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #2f7a40),
              LabelStyle: (
                TextColor: #e4ffe8,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Pressed: (
              Background: (Color: #224f2d),
              LabelStyle: (
                TextColor: #a9f7b6,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Disabled: (
              Background: (Color: #1a3121),
              LabelStyle: (
                TextColor: #5f7a65,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $Sounds.@ButtonsLight
          );
          Text: "";
        }
        TextButton #UpgradeButtonDisabled {
          Anchor: (Width: 250, Height: 36, Right: 8);
          Background: (Color: #612b2b);
          Style: TextButtonStyle(
            Default: (
              LabelStyle: (
                TextColor: #ffd2d2,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Hovered: (
              Background: (Color: #7d3737),
              LabelStyle: (
                TextColor: #ffe6e6,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Pressed: (
              Background: (Color: #502323),
              LabelStyle: (
                TextColor: #ffb3b3,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Disabled: (
              Background: (Color: #341919),
              LabelStyle: (
                TextColor: #7a5f5f,
                RenderBold: true,
                FontSize: 15,
                HorizontalAlignment: Center,
                VerticalAlignment: Center
              )
            ),
            Sounds: $Sounds.@ButtonsLight
          );
          Text: "";
        }
        TextButton #ProjectionPrevButton { Anchor: (Width: 70, Height: 36, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        TextButton #ProjectionButton { Anchor: (Width: 196, Height: 36, Right: 6); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        TextButton #ProjectionNextButton { Anchor: (Width: 70, Height: 36, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        TextButton #CloseButton { Anchor: (Width: 120, Height: 36); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
      }
    }
  }
}


