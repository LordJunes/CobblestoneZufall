$C = "../Common.ui";
$Sounds = "../Sounds.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@Container {
    Anchor: (Width: 1180, Height: 980);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (...$C.@DefaultLabelStyle, FontSize: 22, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 34);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 14, Bottom: 14);

      Group #HotbarRow {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 8);
        Padding: (Left: 8, Right: 8);
        Background: (Color: #23344a(0.9));
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar0Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar0Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar1Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar1Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar2Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar2Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar3Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar3Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar4Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar4Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar5Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar5Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar6Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar6Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34, Right: 2); ItemIcon #Hotbar7Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar7Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group { LayoutMode: Left; Anchor: (Width: 90, Height: 34); ItemIcon #Hotbar8Icon { Anchor: (Width: 22, Height: 22, Right: 4, Left: 2); } TextButton #Hotbar8Pick { Anchor: (Width: 58, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
      }

      Label #HotbarHint {
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #c6d9ff);
        Anchor: (Height: 18, Bottom: 8);
      }

      Group #HeldRow {
        LayoutMode: Left;
        Anchor: (Height: 62, Bottom: 10);
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);
        Background: (Color: #24344a(0.9));
        ItemIcon #HeldIcon { Anchor: (Width: 36, Height: 36, Right: 10); }
        Group {
          LayoutMode: Top;
          FlexWeight: 1;
          Label #HeldName { Style: (...$C.@DefaultLabelStyle, FontSize: 15, TextColor: #88ccff, RenderBold: true); Anchor: (Height: 22); }
          Label #HeldSub { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d8d8d8); Anchor: (Height: 20); }
        }
      }

      Group #TierRow {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 8);
        TextButton #OpenModelButton { Anchor: (Width: 130, Height: 32, Right: 10); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        TextButton #CollectRangeCycleButton { Anchor: (Width: 180, Height: 32, Right: 10); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #a8d8ff, RenderBold: true); Text: "Block Delay"; Anchor: (Width: 82); }
        $C.@TextField #RegenDelayInput { Anchor: (Width: 120, Height: 34, Right: 6); }
        TextButton #SaveRegenDelayButton { Anchor: (Width: 110, Height: 34); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 34, Bottom: 8);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9fd1ff, RenderBold: true); Text: "Expected BPS"; Anchor: (Width: 90); }
        $C.@TextField #ExpectedBpsInput { Anchor: (Width: 120, Height: 30, Right: 6); }
        TextButton #SaveExpectedBpsButton { Anchor: (Width: 110, Height: 30); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
      }

      Group #InputRow {
        LayoutMode: Left;
        Anchor: (Height: 42, Bottom: 8);
        $C.@TextField #ChanceInput { FlexWeight: 1; PlaceholderText: "Chance: 10%, 0.1% or 1/10000"; }
        $C.@TextField #AmountInput { Anchor: (Width: 110, Height: 36, Left: 8, Right: 8); PlaceholderText: "Amount"; }
        TextButton #SaveButton { Anchor: (Width: 170, Height: 36, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
        TextButton #CloseButton { Anchor: (Width: 120, Height: 36); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; }
      }

      Label #ChanceHint { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #c7c7c7); Anchor: (Height: 16, Bottom: 4); }
      Label #AmountHint { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #b8d8ff); Anchor: (Height: 16, Bottom: 4); }
      Label #TotalInfo { Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffde9f, RenderBold: true); Anchor: (Height: 16, Bottom: 8); }

      Group #HeaderRow {
        LayoutMode: Left;
        Anchor: (Height: 26, Bottom: 4);
        Background: (Color: #2e3946(0.9));
        Padding: (Left: 8, Right: 8);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #ffffff, RenderBold: true); Text: "Block"; FlexWeight: 1; }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #ffffff, RenderBold: true); Text: "Chance"; Anchor: (Width: 140); }
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #ffffff, RenderBold: true); Text: "Action"; Anchor: (Width: 220); }
      }

      Group #Entries {
        LayoutMode: TopScrolling;
        Anchor: (Height: 490);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 6);

        Group #Entry0  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry0Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry0Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry0Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry0Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry0Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry1  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry1Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry1Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry1Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry1Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry1Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry2  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry2Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry2Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry2Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry2Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry2Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry3  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry3Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry3Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry3Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry3Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry3Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry4  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry4Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry4Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry4Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry4Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry4Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry5  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry5Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry5Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry5Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry5Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry5Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry6  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry6Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry6Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry6Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry6Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry6Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry7  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry7Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry7Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry7Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry7Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry7Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry8  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry8Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry8Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry8Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry8Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry8Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry9  { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry9Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry9Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry9Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry9Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry9Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry10 { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry10Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry10Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry10Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry10Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry10Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
        Group #Entry11 { LayoutMode: Left; Anchor: (Height: 38, Bottom: 3); Padding: (Left: 8, Right: 8); Background: (Color: #141f2c(0.85)); ItemIcon #Entry11Icon { Anchor: (Width: 24, Height: 24, Right: 8); } Label #Entry11Name { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff); FlexWeight: 1; } Label #Entry11Chance { Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffe08a); Anchor: (Width: 140); } TextButton #Entry11Edit { Anchor: (Width: 104, Height: 28, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } TextButton #Entry11Remove { Anchor: (Width: 104, Height: 28); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: ""; } }
      }
    }
  }
}
