$C = "../Common.ui";
$Sounds = "../Sounds.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@Container {
    Anchor: (Width: 760, Height: 430);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (...$C.@DefaultLabelStyle, FontSize: 22, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Height: 34);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 22, Right: 22, Top: 14, Bottom: 14);

      Label #ItemLabel {
        Style: (...$C.@DefaultLabelStyle, FontSize: 15, TextColor: #9fd1ff, RenderBold: true);
        Anchor: (Height: 24, Bottom: 10);
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 36, Bottom: 8);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d8d8d8, RenderBold: true); Text: "Pay Amount"; Anchor: (Width: 150); }
        $C.@TextField #PayAmountInput { FlexWeight: 1; }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 36, Bottom: 8);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d8d8d8, RenderBold: true); Text: "Drop Amount"; Anchor: (Width: 150); }
        $C.@TextField #DropAmountInput { FlexWeight: 1; }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 36, Bottom: 8);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d8d8d8, RenderBold: true); Text: "Repair Chance %"; Anchor: (Width: 150); }
        $C.@TextField #RepairChanceInput { FlexWeight: 1; }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 36, Bottom: 16);
        Label { Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #d8d8d8, RenderBold: true); Text: "Repair Amount %"; Anchor: (Width: 150); }
        $C.@TextField #RepairAmountInput { FlexWeight: 1; }
      }

      Label {
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #b9c8dd);
        Text: "Repair uses tool max durability (example: 50/200 + 10% => 70/200).";
        Anchor: (Height: 18, Bottom: 14);
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 40);
        TextButton #SaveButton { Anchor: (Width: 160, Height: 34, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: "SAVE"; }
        TextButton #BackButton { Anchor: (Width: 120, Height: 34, Right: 8); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: "BACK"; }
        TextButton #CloseButton { Anchor: (Width: 120, Height: 34); Style: (...$C.@SecondaryTextButtonStyle, Sounds: $Sounds.@ButtonsLight); Text: "CLOSE"; }
      }
    }
  }
}
